{
  "name": "@edwardseshoka/samples",
  "version": "6.0.1",
  "description": "Morara sample data and contract factories.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdwardSeshoka/morara-shared.git",
    "directory": "packages/samples"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@edwardseshoka/contracts": "^4.0.0"
  },
  "scripts": {
    "prebuild": "npm run build --workspace @edwardseshoka/contracts",
    "build": "rm -rf dist && tsc -p tsconfig.json && rsync -am --include='*/' --include='*.json' --exclude='*' src/ dist/",
    "prelint": "npm run build --workspace @edwardseshoka/contracts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm run build && node --test",
    "pretypecheck": "npm run build --workspace @edwardseshoka/contracts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
