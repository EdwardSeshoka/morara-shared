{
  "name": "@edwardseshoka/fixtures",
  "version": "1.0.0",
  "description": "Morara shared fixtures and seed payloads.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdwardSeshoka/morara-shared.git",
    "directory": "packages/fixtures"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./seeds/*": "./dist/seeds/*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && rm -rf dist/seeds && cp -R src/seeds dist/seeds",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
