{
  "name": "@edwardseshoka/contracts",
  "version": "2.1.0",
  "description": "Morara shared DTOs and API contracts.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdwardSeshoka/morara-shared.git",
    "directory": "packages/contracts"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "default": "./dist/catalog/index.js"
    },
    "./provenance": {
      "types": "./dist/provenance/index.d.ts",
      "default": "./dist/provenance/index.js"
    },
    "./editorial": {
      "types": "./dist/editorial/index.d.ts",
      "default": "./dist/editorial/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "default": "./dist/events/index.js"
    },
    "./social": {
      "types": "./dist/social/index.d.ts",
      "default": "./dist/social/index.js"
    },
    "./discover": {
      "types": "./dist/discover/index.d.ts",
      "default": "./dist/discover/index.js"
    },
    "./member": {
      "types": "./dist/member/index.d.ts",
      "default": "./dist/member/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
