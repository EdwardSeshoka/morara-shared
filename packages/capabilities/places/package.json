{
  "name": "@edwardseshoka/places",
  "version": "0.2.2",
  "description": "Morara Places domain and data models.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdwardSeshoka/morara-shared.git",
    "directory": "packages/capabilities/places"
  },
  "type": "module",
  "main": "dist/Domain/index.js",
  "types": "dist/Domain/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/Domain/index.d.ts",
      "default": "./dist/Domain/index.js"
    },
    "./domain": {
      "types": "./dist/Domain/index.d.ts",
      "default": "./dist/Domain/index.js"
    },
    "./domain/test-doubles": {
      "types": "./dist/Domain/TestDoubles/index.d.ts",
      "default": "./dist/Domain/TestDoubles/index.js"
    },
    "./data": {
      "types": "./dist/Data/index.d.ts",
      "default": "./dist/Data/index.js"
    },
    "./data/test-doubles": {
      "types": "./dist/Data/TestDoubles/index.d.ts",
      "default": "./dist/Data/TestDoubles/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "prebuild": "npm run build --workspace @edwardseshoka/foundation",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "prelint": "npm run build --workspace @edwardseshoka/foundation",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm run build && node --test",
    "pretypecheck": "npm run build --workspace @edwardseshoka/foundation",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@edwardseshoka/foundation": "^2.0.0"
  }
}
