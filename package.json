{
  "name": "morara-shared",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "find . -name dist -type d -prune -exec rm -rf {} +",
    "lint": "npm run lint --workspaces --if-present",
    "release:version": "node ./scripts/release-version.mjs --print",
    "release:version:check": "node ./scripts/release-version.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces",
    "version:sync": "npm version --workspaces --include-workspace-root=true --no-git-tag-version"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
